# ── Base de données ────────────────────────────────────────────────────────────
# En prod : URL Neon (postgres://user:password@host/dbname?sslmode=require)
DATABASE_URL=

# ── Secrets (générer avec : openssl rand -hex 32) ─────────────────────────────
JWT_SECRET=
COOKIE_SECRET=

# ── CORS (URLs de ton frontend et admin en prod) ───────────────────────────────
STORE_CORS=https://golden-vape.fr
ADMIN_CORS=https://admin.golden-vape.fr
AUTH_CORS=https://admin.golden-vape.fr

# ── URL publique du backend ────────────────────────────────────────────────────
MEDUSA_BACKEND_URL=https://api.golden-vape.fr

# ── Redis (Railway fournit REDIS_URL automatiquement) ─────────────────────────
REDIS_URL=

# ── Cloudflare R2 ─────────────────────────────────────────────────────────────
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=golden-vape-media
R2_PUBLIC_URL=

# ── Hiboutik (Settings → API dans Hiboutik) ───────────────────────────────────
HIBOUTIK_ACCOUNT=
HIBOUTIK_USER=
HIBOUTIK_API_KEY=
